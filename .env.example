# PostgreSQL connection for Prisma runtime and migrations
# Update username/password/host/database to your local setup
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/salio_crm?schema=public"

# Optional defaults used by deals service
DEFAULT_PIPELINE_ID="00000000-0000-0000-0000-000000000001"
DEFAULT_ASSIGNEE_ID="00000000-0000-0000-0000-000000000010"
